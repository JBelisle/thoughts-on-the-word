---
import Base from '../layouts/Base.astro';
---
<Base title="Search" description="Search studies, essays, and reading plans.">
  <h1>Search</h1>
  <div id="search"></div>
  <p class="muted small" style="text-align:center;margin-top:12px">
    Search runs on the built site. Run <code>npm run build</code> then <code>npm run preview</code> to try it locally.
  </p>
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function () {
      if (window.PagefindUI) {
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: true,
          // Surface each result's date under the title so duplicate-named entries
          // (e.g. multiple "Thoughts on Galatians 1") are distinguishable.
          processResult: function (result) {
            if (result && result.meta && result.meta.date) {
              result.excerpt = '<span class="search-result-date">' + result.meta.date + '</span>' + result.excerpt;
            }
            return result;
          },
        });
      }
    });
  </script>
</Base>
